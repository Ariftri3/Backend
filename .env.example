# Copy file ini menjadi .env di folder Backend
# Semua nilai diambil dari Supabase Dashboard project kamu

# Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=isi-dengan-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=isi-dengan-service-role-key

# Settings > Database > Connection string > URI
# (pakai mode "Session pooler" / port 5432, ganti [YOUR-PASSWORD] dengan password database kamu)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
# Ubah nilai sesuai pengaturan MySQL di mesin kamu

SECRET_KEY=capstone_mental_health_2026
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=mental_health_app
DB_PORT=3306
